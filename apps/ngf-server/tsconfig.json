{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@kibbel/ngf-core": ["../../packages/ngf-core/src/index.ts"],
      "@kibbel/ngf-csv": ["../../packages/ngf-csv/src/index.ts"],
      "@kibbel/ngf-db": ["../../packages/ngf-db/src/index.ts"],
      "@kibbel/ngf-validate": ["../../packages/ngf-validate/src/index.ts"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
